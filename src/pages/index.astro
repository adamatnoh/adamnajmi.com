---
import Chatbot from '../components/Chatbot';
import DailyCipher from '../components/DailyCipher';
import Word from '../components/Word.astro';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Adam Najmi · Software Engineer</title>
    <style>
      /* A tiny custom blink animation for the terminal cursor */
      .cursor-blink {
        animation: blink 1s step-end infinite;
      }
      @keyframes blink {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0;
        }
      }
      /* Smooth fade-in for the page */
      body {
        background-color: #0a0a0a;
        color: #e5e5e5;
        font-family: 'Inter', sans-serif;
      }
    </style>
  </head>
  <style>
    @import '../styles/global.css';
  </style>
  <body class="min-h-screen flex items-center justify-center p-6">
    <!-- Main Container -->
    <div class="max-w-4xl w-full space-y-16">
      <!-- ========== HERO SECTION ========== -->
      <section class="space-y-6">
        <!-- The Terminal Intro -->
        <div class="bg-black border border-white/10 rounded-lg p-6 shadow-2xl">
          <div class="flex items-center gap-2 border-b border-white/10 pb-3 mb-4">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
            <span class="text-white/30 text-xs ml-2 font-mono">zsh — 80×24</span>
          </div>

          <div class="font-mono text-sm md:text-base space-y-2">
            <p>
              <span class="text-green-400">➜</span>
              <span class="text-white/60">~</span>
              <span class="text-white">whoami</span>
            </p>
            <!-- Avatar + Name -->
            <div class="flex items-center gap-3">
              <div class="relative group inline-block cursor-pointer">
                <p class="text-white font-bold text-xl md:text-3xl tracking-tight">
                  Adam <Word word="Najmi" />
                </p>
                <!-- Preview on hover -->
                <div
                  class="absolute left-0 top-full mt-2 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-opacity duration-200 z-10"
                >
                  <div class="bg-black border border-white/10 rounded-lg shadow-2xl p-1">
                    <img
                      src="/file/adam.png"
                      alt="Adam Najmi"
                      class="min-w-32 h-32 object-cover rounded-md"
                    />
                  </div>
                </div>
              </div>
            </div>
            <p>
              <span class="text-green-400">➜</span>
              <span class="text-white/60">~</span>
              <span class="text-white">cat /etc/profile</span>
            </p>
            <p class="text-white/80 text-lg md:text-2xl font-light">
              Software Engineer · <span class="text-white font-medium">Backend & Fintech</span>
            </p>
            <p>
              <span class="text-green-400">➜</span>
              <span class="text-white/60">~</span>
              <span class="text-cyan-400">./adam --location</span>
            </p>
            <p class="text-white/60">
              <Word word="Johor" />, Malaysia <span class="text-white/30">|</span> Open to Remote & On-site
            </p>
            <div class="pt-1 flex flex-wrap gap-4 items-center">
              <span class="text-green-400">➜</span>
              <a
                href={import.meta.env.RESUME_URL}
                target="_blank"
                class="text-white border border-white/20 px-4 py-1 rounded hover:bg-white hover:text-black transition text-sm"
                >Open Resume</a
              >
              <a
                href={import.meta.env.LINKEDIN_URL}
                target="_blank"
                class="text-white/60 hover:text-white transition text-sm"
                >linkedin.com/in/adamnajmi</a
              >
              <a
                href={import.meta.env.GITHUB_URL}
                target="_blank"
                class="text-white/60 hover:text-white transition text-sm">github.com/adamatnoh</a
              >
            </div>
            <p class="pt-2 text-white/30 text-xs">
              <span class="cursor-blink inline-block w-2 h-4 bg-white align-middle"></span>
              <!-- Blinking cursor -->
            </p>
          </div>
        </div>
        <!-- End Terminal -->
      </section>

      <!-- ========== TECH STACK ========== -->
      <section>
        <div class="flex items-center gap-4 mb-6 border-b border-white/10 pb-2">
          <span class="text-green-400 font-mono text-sm">⚙️</span>
          <h2 class="text-2xl font-mono font-bold text-white">tech_stack</h2>
          <span class="text-white/30 text-sm font-mono">// Languages & <Word word="Tools" /></span>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          {
            [
              'TypeScript',
              'JavaScript',
              'Node.js',
              'NestJS',
              'Laravel',
              'PHP',
              'React Native',
              'MySQL',
              'Prisma',
              'Power BI',
              'Docker',
              'Git',
            ].map((tech) => (
              <div
                data-word={tech}
                onclick="window.guessWord && window.guessWord(this.dataset.word)"
                class="bg-white/5 border border-white/10 rounded-md px-4 py-2 text-center text-white/80 text-sm font-mono hover:bg-white hover:text-black hover:border-white transition cursor-pointer"
              >
                {tech}
              </div>
            ))
          }
        </div>
      </section>

      <!-- ========== EXPERIENCE ========== -->
      <section>
        <div class="flex items-center gap-4 mb-6 border-b border-white/10 pb-2">
          <span class="text-green-400 font-mono text-sm">💻</span>
          <h2 class="text-2xl font-mono font-bold text-white">experience</h2>
          <span class="text-white/30 text-sm font-mono">// Work History</span>
        </div>

        <!-- Rapidz -->
        <div
          class="bg-black border border-white/10 rounded-lg p-6 mb-6 hover:border-white/30 transition"
        >
          <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-2 mb-3">
            <div>
              <h3 class="text-xl font-mono font-bold text-white">Rapidz Inc.</h3>
              <p class="text-cyan-400 font-mono text-sm">Web Developer · 2+ Years</p>
            </div>
            <span
              class="text-white/20 text-sm font-mono border border-white/10 px-3 py-1 rounded-full"
              >Fintech · Crypto</span
            >
          </div>
          <ul
            class="space-y-2 font-mono text-white/70 text-sm list-disc list-inside marker:text-green-400"
          >
            <li>
              Implemented HMAC request signing &amp; JWT (RS256) authentication for secure APIs.
            </li>
            <li>
              <Word word="Built" /> a push notification <Word word="queue" /> (FCM) handling millions
              of
              <Word word="daily" /> events.
            </li>
            <li>
              Designed a Power BI reporting ecosystem (P&amp;L, <Word word="yield" />, product
              performance) from scratch.
            </li>
            <li>
              Championed on migration from Laravel/PHP to NestJS + <Word word="React" /> Native <Word
                word="stack"
              />.
            </li>
          </ul>
        </div>

        <!-- Intel -->
        <div
          class="bg-black border border-white/10 rounded-lg p-6 hover:border-white/30 transition"
        >
          <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-2 mb-3">
            <div>
              <h3 class="text-xl font-mono font-bold text-white">
                <Word word="Intel" /> Corporation
              </h3>
              <p class="text-cyan-400 font-mono text-sm">Software Engineering Intern</p>
            </div>
            <span
              class="text-white/20 text-sm font-mono border border-white/10 px-3 py-1 rounded-full"
              >Semiconductor</span
            >
          </div>
          <ul
            class="space-y-2 font-mono text-white/70 text-sm list-disc list-inside marker:text-green-400"
          >
            <li>Developed Python &amp; Perl scripts for GUI automation and verification.</li>
            <li>Worked with Verilog &amp; SystemVerilog for hardware validation flows.</li>
            <li>Collaborated across global teams (US, Malaysia) to deliver testing frameworks.</li>
          </ul>
        </div>
      </section>

      <!-- ========== PROJECTS ========== -->
      <section>
        <div class="flex items-center gap-4 mb-6 border-b border-white/10 pb-2">
          <span class="text-green-400 font-mono text-sm">🖥️</span>
          <h2 class="text-2xl font-mono font-bold text-white">projects</h2>
          <span class="text-white/30 text-sm font-mono">// Project Builds</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Rapidz -->
          <div
            class="bg-black border border-green-500/10 rounded-md p-4 hover:border-green-500/30 transition flex flex-col"
          >
            <div class="flex items-center gap-2 mb-1">
              <span class="text-green-400 font-mono text-sm">$</span>
              <h3 class="text-white font-mono font-bold text-base">rapidz</h3>
            </div>
            <div class="flex flex-wrap gap-2 mb-2">
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#rapidz-inc</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#crypto</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#api</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#nestjs</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#react-native</span
              >
            </div>
            <p class="text-white/50 text-xs md:text-[13px] font-mono mb-2">
              Production-<Word word="grade" /> wallet serving thousands of <Word word="users" /> globally.
            </p>
            <div class="space-y-1 text-white/60 text-xs md:text-[13px] font-mono flex-1">
              <p><span class="text-green-400/50">></span> Deposit / Withdraw crypto</p>
              <p>
                <span class="text-green-400/50">></span> Hold & receive digital collectibles (NFT)
              </p>
              <p>
                <span class="text-green-400/50">></span>
                <Word word="Stake" /> &amp; earn real <Word word="yield" />
                <Word word="rates" />
              </p>
              <p>
                <span class="text-green-400/50">></span> Instant <Word word="swaps" /> (20+ cryptos)
              </p>
              <p><span class="text-green-400/50">></span> Rapidz Card spending integration</p>
            </div>
          </div>

          <!-- Verrefin -->
          <div
            class="bg-black border border-green-500/10 rounded-md p-4 hover:border-green-500/30 transition flex flex-col"
          >
            <div class="flex items-center gap-2 mb-1">
              <span class="text-green-400 font-mono text-sm">$</span>
              <h3 class="text-white font-mono font-bold text-base">verrefin</h3>
            </div>
            <div class="flex flex-wrap gap-2 mb-2">
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#rapidz-inc</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#defi</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#webapp</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#nestjs</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#react-native</span
              >
            </div>
            <p class="text-white/50 text-xs md:text-[13px] font-mono mb-2">
              Neo crypto bank unifying traditional and decentralized finance.
            </p>
            <div class="space-y-1 text-white/60 text-xs md:text-[13px] font-mono flex-1">
              <p>
                <span class="text-green-400/50">></span> Fiat wallet & <Word word="cross" />-border
                payments
              </p>
              <p>
                <span class="text-green-400/50">></span> Earn yields through ecosystem <Word
                  word="vault"
                />
              </p>
              <p>
                <span class="text-green-400/50">></span> 70% <Word word="lower" /> fees than traditional
                <Word word="banks" />
              </p>
              <p><span class="text-green-400/50">></span> Co-branded card program</p>
            </div>
          </div>

          <!-- Admin Portal -->
          <div
            class="bg-black border border-green-500/10 rounded-md p-4 hover:border-green-500/30 transition flex flex-col"
          >
            <div class="flex items-center gap-2 mb-1">
              <span class="text-green-400 font-mono text-sm">$</span>
              <h3 class="text-white font-mono font-bold text-base">
                <Word word="admin" />-portal
              </h3>
            </div>
            <div class="flex flex-wrap gap-2 mb-2">
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#rapidz-inc</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#<Word word="admin" /></span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#webapp</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#laravel</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#php</span
              >
            </div>
            <p class="text-white/50 text-xs md:text-[13px] font-mono mb-2">
              Internal management portal for Rapidz administrators.
            </p>
            <div class="space-y-1 text-white/60 text-xs md:text-[13px] font-mono flex-1">
              <p>
                <span class="text-green-400/50">></span> Deposit / Withdraw <Word word="admin" />
                <Word word="funds" />
              </p>
              <p>
                <span class="text-green-400/50">></span> User account &amp; transaction management
              </p>
              <p>
                <span class="text-green-400/50">></span> Bulk <Word word="email" />
                distribution to <Word word="users" />
              </p>
            </div>
          </div>

          <!-- Merchant Portal -->
          <div
            class="bg-black border border-green-500/10 rounded-md p-4 hover:border-green-500/30 transition flex flex-col"
          >
            <div class="flex items-center gap-2 mb-1">
              <span class="text-green-400 font-mono text-sm">$</span>
              <h3 class="text-white font-mono font-bold text-base">merchant-portal</h3>
            </div>
            <div class="flex flex-wrap gap-2 mb-2">
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#rapidz-inc</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#merchant</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#webapp</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#laravel</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#php</span
              >
            </div>
            <p class="text-white/50 text-xs md:text-[13px] font-mono mb-2">
              Management portal for Rapidz merchants/clients.
            </p>
            <div class="space-y-1 text-white/60 text-xs md:text-[13px] font-mono flex-1">
              <p>
                <span class="text-green-400/50">></span>
                <Word word="Staff" /> account &amp; role management
              </p>
              <p>
                <span class="text-green-400/50">></span> Virtual card issuance &amp; distribution
              </p>
              <p>
                <span class="text-green-400/50">></span>
                <Word word="Token" />/NFT airdrops for campaigns
              </p>
            </div>
          </div>

          <!-- Telegram Bot -->
          <div
            class="bg-black border border-green-500/10 rounded-md p-4 hover:border-green-500/30 transition flex flex-col"
          >
            <div class="flex items-center gap-2 mb-1">
              <span class="text-green-400 font-mono text-sm">$</span>
              <h3 class="text-white font-mono font-bold text-base">telegram-bot</h3>
            </div>
            <div class="flex flex-wrap gap-2 mb-2">
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#rapidz-inc</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#telegram</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#bot</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#nodejs</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#nestjs</span
              >
            </div>
            <p class="text-white/50 text-xs md:text-[13px] font-mono mb-2">
              Trading bot enabling crypto/fiat exchange via Telegram.
            </p>
            <div class="space-y-1 text-white/60 text-xs md:text-[13px] font-mono flex-1">
              <p>
                <span class="text-green-400/50">></span> Buy &amp; sell crypto with integrated <Word
                  word="rates"
                />
              </p>
              <p>
                <span class="text-green-400/50">></span> Custom <Word word="rates" /> per client/<Word
                  word="agent"
                />
              </p>
              <p>
                <span class="text-green-400/50">></span>
                <Word word="Agent" />-assisted transactions on behalf of clients
              </p>
            </div>
          </div>

          <!-- Power BI Reporting -->
          <div
            class="bg-black border border-green-500/10 rounded-md p-4 hover:border-green-500/30 transition flex flex-col"
          >
            <div class="flex items-center gap-2 mb-1">
              <span class="text-green-400 font-mono text-sm">$</span>
              <h3 class="text-white font-mono font-bold text-base">
                <Word word="power" />-bi-analytics
              </h3>
            </div>
            <div class="flex flex-wrap gap-2 mb-2">
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#rapidz-inc</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#ms-<Word word="power" />-bi</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#dax</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#reporting</span
              >
            </div>
            <p class="text-white/50 text-xs md:text-[13px] font-mono mb-2">
              Real-time Rapidz executive dashboards for revenue, <Word word="yield" />, and product
              performance.
            </p>
            <div class="space-y-1 text-white/60 text-xs md:text-[13px] font-mono flex-1">
              <p>
                <span class="text-green-400/50">></span> Real-time <Word word="power" /> P&amp;L &amp;
                <Word word="yield" /> tracking
              </p>
              <p><span class="text-green-400/50">></span> Product performance dashboards</p>
              <p><span class="text-green-400/50">></span> Data-driven executive decision-making</p>
            </div>
          </div>

          <!-- HSS (Final Year Project) -->
          <div
            class="bg-black border border-green-500/10 rounded-md p-4 hover:border-green-500/30 transition flex flex-col md:col-span-2"
          >
            <div class="flex items-center gap-2 mb-1">
              <span class="text-green-400 font-mono text-sm">$</span>
              <h3 class="text-white font-mono font-bold text-base">hospital-scheduling-system</h3>
            </div>
            <div class="flex flex-wrap gap-2 mb-2">
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#fyp-utm</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#healthcare</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#webapp</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#laravel</span
              >
              <span class="text-[10px] font-mono text-cyan-400 bg-cyan-400/10 px-2 py-0.5 rounded"
                >#php</span
              >
            </div>
            <p class="text-white/50 text-xs md:text-[13px] font-mono mb-2">
              <Word word="Final" /> Year Project – Hospital scheduling system streamlining appointments
              and resource management.
            </p>
            <div
              class="grid grid-cols-1 sm:grid-cols-2 gap-1 text-white/60 text-xs md:text-[13px] font-mono flex-1"
            >
              <div class="space-y-1">
                <p><span class="text-green-400/50">></span> Real-time availability booking</p>
                <p><span class="text-green-400/50">></span> Doctor schedule management</p>
              </div>
              <div class="space-y-1">
                <p><span class="text-green-400/50">></span> Automated reminders & notifications</p>
                <p><span class="text-green-400/50">></span> Administrative oversight dashboard</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ========== FOOTER / CONTACT ========== -->
      <footer class="border-t border-white/10 pt-8 text-center text-white/30 text-xs font-mono">
        <p>
          adamnajmi.com ·
          <a href="mailto:adamnajminoh@gmail.com" class="text-white/50 hover:text-white"
            >adamnajminoh@gmail.com</a
          > ·
          <span class="text-green-400">●</span> Open for opportunities
        </p>
      </footer>
    </div>
    <Chatbot client:load />
    <DailyCipher client:load />
  </body>
</html>
